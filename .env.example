# Google Gemini API Key
GOOGLE_API_KEY=your_gemini_api_key_here

# Target Course Information
COURSE_NAME="2028_MBU_60 days Skill Development Assessment Course"

# Saved Accounts
# Next time the user says "do Day X", read these accounts and run the automation for all of them.
ACCOUNT_1_EMAIL=account1@example.com
ACCOUNT_1_PASS=account1_password

ACCOUNT_2_EMAIL=account2@example.com
ACCOUNT_2_PASS=account2_password
# Proxy Configuration (comma-separated, leave empty to disable proxy rotation)
# Example: PROXY_LIST=http://user:pass@proxy1.com:8000,http://user:pass@proxy2.com:8000
PROXY_LIST=

# Redis Configuration (optional — falls back to local JSON if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379

# PocketBase Configuration (for HITL dashboard)
POCKETBASE_URL=http://127.0.0.1:8090
